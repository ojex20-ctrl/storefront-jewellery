# --- Brand identity ---
# Most of these are now sourced from /store/brand-config/:handle at runtime.
# These envs are FALLBACKS used when the backend is unreachable in dev.
NEXT_PUBLIC_BRAND=PODIUM PARFUM
NEXT_PUBLIC_BRAND_HANDLE=perfumes
NEXT_PUBLIC_BRAND_TAGLINE=A library of scent|in small flacons
NEXT_PUBLIC_DEFAULT_REGION=ae
NEXT_PUBLIC_DEFAULT_CURRENCY=AED

# --- Medusa backend ---
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Use the "PODIUM Perfumes" publishable key from `pnpm --filter @podium/backend seed`
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# --- Payments ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Supabase customer auth ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- SMTP email ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
ADMIN_ORDER_ALERT_EMAIL=

# --- Social / support ---
ADMIN_WHATSAPP_NUMBER=
PUBLIC_WHATSAPP_NUMBER=
PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hi, I need help with my order

# --- Cloudinary ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Meilisearch ---
NEXT_PUBLIC_MEILI_HOST=http://localhost:7700
NEXT_PUBLIC_MEILI_SEARCH_KEY=
