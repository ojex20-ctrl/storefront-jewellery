# --- Brand identity ---
# Most of these are now sourced from /store/brand-config/:handle at runtime.
# These envs are FALLBACKS used when the backend is unreachable in dev.
NEXT_PUBLIC_BRAND=PODIUM PARFUM
NEXT_PUBLIC_BRAND_HANDLE=perfumes
NEXT_PUBLIC_BRAND_TAGLINE=A library of scent|in small flacons
NEXT_PUBLIC_DEFAULT_REGION=ae
NEXT_PUBLIC_DEFAULT_CURRENCY=AED

# --- Medusa backend ---
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Use the "PODIUM Perfumes" publishable key from `pnpm --filter @podium/backend seed`
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# --- Payments ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Supabase customer auth ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (MongoDB) ---
# MongoDB connection string. Prisma requires a replica set (even single-node)
# for transactions — note the ?replicaSet=rs0 parameter.
DATABASE_URL=mongodb://127.0.0.1:27017/syra?replicaSet=rs0

# --- Media / product-image storage ---
# Absolute path OUTSIDE the code tree so redeploys never delete uploaded images.
# Served at the /uploads/ URL prefix (nginx alias in prod). Leave unset for local
# dev (falls back to public/uploads). Product images go under products/<slug>/.
MEDIA_ROOT=/var/www/syra-media

# --- SMTP email (Gmail) ---
# Use a Gmail App Password (Account → Security → App passwords), NOT your login
# password. Requires 2-Step Verification. Spaces in the app password are ignored.
# SMTP_FROM / SMTP_FROM_EMAIL / EMAIL_FROM are all accepted for the From header.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=SYRA <youraddress@gmail.com>
SMTP_FROM_EMAIL=
ADMIN_ORDER_ALERT_EMAIL=

# --- Auth sessions (server-side, REQUIRED) ---
# No fallback — the app refuses to sign/verify tokens if these are unset.
# Generate each with: openssl rand -hex 32
ADMIN_JWT_SECRET=
NEXTAUTH_SECRET=

# --- Social / support ---
ADMIN_WHATSAPP_NUMBER=
PUBLIC_WHATSAPP_NUMBER=
PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hi, I need help with my order

# --- Cloudinary ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Meilisearch ---
NEXT_PUBLIC_MEILI_HOST=http://localhost:7700
NEXT_PUBLIC_MEILI_SEARCH_KEY=

# --- One-time admin setup endpoint (POST /api/admin/setup) ---
# The endpoint returns 404 unless this is set. Generate with: openssl rand -hex 32
# Unset it again once the admin user has been created.
SETUP_SECRET=

# --- Database seed (prisma db seed) ---
# The seed only creates an admin user when BOTH are set. No hardcoded defaults.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
