# --- Brand identity ---
# Most of these are now sourced from /store/brand-config/:handle at runtime.
# These envs are FALLBACKS used when the backend is unreachable in dev.
NEXT_PUBLIC_BRAND=PODIUM PARFUM
NEXT_PUBLIC_BRAND_HANDLE=perfumes
NEXT_PUBLIC_BRAND_TAGLINE=A library of scent|in small flacons
NEXT_PUBLIC_DEFAULT_REGION=ae
NEXT_PUBLIC_DEFAULT_CURRENCY=AED

# --- Medusa backend ---
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Use the "PODIUM Perfumes" publishable key from `pnpm --filter @podium/backend seed`
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# --- Payments ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Cloudinary ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Meilisearch ---
NEXT_PUBLIC_MEILI_HOST=http://localhost:7700
NEXT_PUBLIC_MEILI_SEARCH_KEY=

# --- Customer authentication (server-side, REQUIRED) ---
# Signing secret for customer session JWTs. No fallback. Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# --- Admin authentication (server-side, REQUIRED) ---
# Signing secret for admin JWTs. No fallback — the app refuses to sign/verify
# tokens if this is unset. Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=

# --- One-time admin setup endpoint (POST /api/admin/setup) ---
# The endpoint returns 404 unless this is set. Generate with: openssl rand -hex 32
# Unset it again once the admin user has been created.
SETUP_SECRET=

# --- Database seed (prisma db seed) ---
# The seed only creates an admin user when BOTH are set. No hardcoded defaults.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin

# --- Email (Gmail SMTP via nodemailer) ---
# Use a Gmail App Password (Account → Security → App passwords), NOT your login password.
# Requires 2-Step Verification enabled on the Gmail account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
# From header must match SMTP_USER for Gmail.
EMAIL_FROM=SYRA <youraddress@gmail.com>
