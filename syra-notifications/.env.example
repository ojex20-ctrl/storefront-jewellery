# Resend (free 100 emails/day)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXX

EMAIL_FROM=SYRA <noreply@yourdomain.com>

# ─── WhatsApp Cloud API (disabled by default) ───
