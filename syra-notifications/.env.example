# ─── Database ───
DATABASE_URL=postgresql://syra:CHANGE_ME_DB_PASSWORD@db:5432/syra_notifications
REDIS_URL=redis://redis:6379

# ─── App ───
APP_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
