# ─── Database ───
DATABASE_URL=postgresql://syra:CHANGE_ME_DB_PASSWORD@db:5432/syra_notifications
REDIS_URL=redis://redis:6379

# ─── App ───
APP_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
APP_URL=https://notify.yourdomain.com
PORT=4000

# ─── Email (Gmail SMTP via nodemailer) ───
# Use a Gmail App Password (requires 2-Step Verification), NOT the login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
# From header must match SMTP_USER for Gmail.
EMAIL_FROM=SYRA <youraddress@gmail.com>

# ─── WhatsApp Cloud API (disabled by default) ───
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ─── Admin ───
ADMIN_EMAIL=admin@syra.in
ADMIN_PASSWORD=adnan123

# ─── SSL Domain ───
DOMAIN=notify.yourdomain.com
